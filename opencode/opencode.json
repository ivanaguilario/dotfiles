{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "aws-knowledge": {
      "type": "local",
      "command": [
        "uvx",
        "fastmcp",
        "run",
        "https://knowledge-mcp.global.api.aws"
      ]
    },
    "terraform": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server:0.5.2"
      ]
    }
  }
}
